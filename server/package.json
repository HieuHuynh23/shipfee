{
  "name": "shipfee-proxy-server",
  "version": "1.1.0",
  "description": "Proxy server tự động lấy data quán ăn từ ShopeeFood Cần Thơ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "npx puppeteer browsers install chrome",
    "crawl:menus": "node crawl_restaurant_menus.js --only-fallback --open-only",
    "crawl:menus:one": "node crawl_restaurant_menus.js --id",
    "crawl:menus:dry": "node crawl_restaurant_menus.js --only-fallback --open-only --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.2",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.3.0",
    "puppeteer": "^22.10.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
