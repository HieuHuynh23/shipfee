{
  "name": "shipfee-proxy-server",
  "version": "1.1.0",
  "description": "Proxy server tự động lấy data quán ăn từ ShopeeFood Cần Thơ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "node -e \"if(process.env.RENDER){console.log('[postinstall] Skip Chrome on Render');process.exit(0)}require('child_process').execSync('npx puppeteer browsers install chrome',{stdio:'inherit'})\"",
    "crawl:menus": "node crawl_restaurant_menus.js --only-fallback --open-only",
    "crawl:menus:one": "node crawl_restaurant_menus.js --id",
    "crawl:menus:dry": "node crawl_restaurant_menus.js --only-fallback --open-only --dry-run",
    "crossref:gps": "node crossref_foody_gps.js --only-missing",
    "crossref:gps:all": "node crossref_foody_gps.js --include-heuristic --all --concurrency=4",
    "crossref:gps:address": "node crossref_address_gps.js --all",
    "crossref:gps:one": "node crossref_foody_gps.js --id"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "puppeteer": "^22.10.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5"
  }
}
